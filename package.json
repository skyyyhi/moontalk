{
  "name": "moontalk",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "node --experimental-sqlite server/index.js",
    "dev": "concurrently \"node --experimental-sqlite --watch server/index.js\" \"npm run dev --prefix client\"",
    "build": "npm run build --prefix client",
    "test": "node --experimental-sqlite --test \"server/**/*.test.js\"",
    "test:client": "npm test --prefix client",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "node-fetch": "^3.3.2",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "concurrently": "^8.2.2",
    "supertest": "^7.0.0"
  }
}
